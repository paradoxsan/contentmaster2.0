rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users: can only read/write their own document
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Meta accounts: users can only access their own linked accounts
    match /metaAccounts/{accountId} {
      allow read: if request.auth != null
        && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null
        && resource.data.userId == request.auth.uid;
    }

    // Posts: users can only access their own posts
    match /posts/{postId} {
      allow read: if request.auth != null
        && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null
        && resource.data.userId == request.auth.uid;
    }

    // Scheduled jobs: read-only for users, write-only for Cloud Functions
    match /scheduledJobs/{jobId} {
      allow read: if request.auth != null
        && resource.data.userId == request.auth.uid;
      allow write: if false;
    }

    // Meta tokens: completely locked down — admin SDK only
    match /metaTokens/{tokenId} {
      allow read, write: if false;
    }
  }
}
